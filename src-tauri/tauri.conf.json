{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BBDG HWP Editor",
  "version": "0.7.93",
  "identifier": "com.bbdg.hwp-editor",
  "build": {
    "beforeDevCommand": "powershell -NoProfile -Command \"Set-Location '../rhwp-studio'; npm run dev -- --host localhost --port 7700\"",
    "beforeBuildCommand": "powershell -NoProfile -Command \"Set-Location '../rhwp-studio'; npm run build\"",
    "devUrl": "http://localhost:7700",
    "frontendDist": "../rhwp-studio/dist"
  },
  "app": {
    "windows": [
      {
        "title": "BBDG HWP Editor",
        "width": 1200,
        "height": 800,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"],
    "publisher": "BBD Global Co., Ltd.",
    "windows": {
      "wix": {
        "language": ["ko-KR"]
      },
      "nsis": {
        "languages": ["Korean"]
      }
    }
  }
}
